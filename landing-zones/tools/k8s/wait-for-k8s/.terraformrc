
provider_installation {

   "filesystem_mirror" {
    include = ["registry.terraform.io/*/*", "registry.opentofu.org/*/*"]
    path    = "/Users/frederic/Documents/_work/119_hoverkraft-tech/src/blueprints/vcluster/.terragrunt-cache/terragrunt/providers"
  }
   "direct" {
  }
}

plugin_cache_dir = ""

host "registry.terraform.io" {
  services = {
    "modules.v1"   = "https://registry.terraform.io/v1/modules/"
    "providers.v1" = "http://127.0.0.1:49549/v1/providers//registry.terraform.io/"
  }
}
host "registry.opentofu.org" {
  services = {
    "modules.v1"   = "https://registry.opentofu.org/v1/modules/"
    "providers.v1" = "http://127.0.0.1:49549/v1/providers//registry.opentofu.org/"
  }
}

disable_checkpoint           = true
disable_checkpoint_signature = false
